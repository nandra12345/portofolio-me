# Database Configuration
# Copy file ini ke api/config.php dan sesuaikan nilai-nilainya

# Database Host (biasanya localhost)
DB_HOST=localhost

# Nama Database
DB_NAME=portfolio_db

# Username Database
DB_USER=root

# Password Database (kosongkan jika tidak ada password)
DB_PASS=

# Charset Database
DB_CHARSET=utf8mb4

# Security Settings
# Minimal jeda waktu antar komentar dalam detik
RATE_LIMIT_SECONDS=60

# Maksimal panjang komentar
MAX_COMMENT_LENGTH=500

# Allowed Origins untuk CORS (ganti dengan domain kamu saat production)
ALLOWED_ORIGINS=http://localhost:8000

# Debug Mode (set ke false di production!)
DEBUG_MODE=true

# ==========================================
# PRODUCTION SETTINGS (saat deploy online)
# ==========================================

# Contoh untuk hosting shared (cPanel):
# DB_HOST=localhost
# DB_NAME=username_portfolio
# DB_USER=username_dbuser
# DB_PASS=strong_password_here

# Contoh untuk hosting dengan IP:
# DB_HOST=192.168.1.100
# DB_NAME=portfolio_db
# DB_USER=portfolio_user
# DB_PASS=secure_password_123

# CORS untuk production:
# ALLOWED_ORIGINS=https://yourdomain.com

# WAJIB set DEBUG_MODE ke false di production:
# DEBUG_MODE=false